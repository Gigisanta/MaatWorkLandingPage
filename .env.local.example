# MaatWork Landing Page - Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# -----------------------------------------
# Neon Database (Vercel Postgres)
# -----------------------------------------
# When you create a Vercel Postgres database with Neon provider,
# Vercel automatically sets the DATABASE_URL environment variable.
# Format: postgresql://user:***@host/dbname?sslmode=require
DATABASE_URL=postgresql://username:***@your-endpoint.neon.tech/neondb?sslmode=require

# -----------------------------------------
# CORS (optional)
# -----------------------------------------
# ALLOWED_ORIGIN=https://maatwork.com
