# ===========================================
# Maatwork - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# -----------------------------------------
# NeonDB (Database)
# -----------------------------------------
# Get this from your NeonDB dashboard: https://neon.tech/docs/connect/connect-from-any-framework
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://username:password@your-endpoint.neon.tech/neondb?sslmode=require

# -----------------------------------------
# Slack Integration (Optional)
# -----------------------------------------
# Create a Slack App at https://api.slack.com/apps
# Enable Incoming Webhooks and add a webhook URL
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# -----------------------------------------
# Vercel Deployment
# -----------------------------------------
# Set these in your Vercel project dashboard:
# https://vercel.com/dashboard -> Your Project -> Settings -> Environment Variables
#
# IMPORTANT: Add ALL environment variables to Vercel, including:
# - DATABASE_URL
# - SLACK_WEBHOOK_URL (if using Slack notifications)
