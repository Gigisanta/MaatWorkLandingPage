# ===========================================
# Maatwork - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# -----------------------------------------
# Neon Database (Vercel Postgres)
# -----------------------------------------
# When you create a Vercel Postgres database with Neon provider,
# Vercel automatically sets the DATABASE_URL environment variable.
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://username:password@your-endpoint.neon.tech/neondb?sslmode=require

# -----------------------------------------
# Vercel Deployment
# -----------------------------------------
# IMPORTANT: Add ALL environment variables to Vercel, including:
# - DATABASE_URL (auto-configured when using Vercel Postgres with Neon)
#
# Vercel automatically sets these during build for Serverless Functions.
# For local development, add them to .env.local